# Required Globus OAuth client (App 2: connector app)
GLOBUS_CLIENT_ID=replace_me
GLOBUS_CLIENT_SECRET=replace_me
GLOBUS_REDIRECT_URI=http://localhost:8000/callback

# Comma separated. Keep openid/profile/email + Globus Compute scope.
GLOBUS_SCOPES=openid,profile,email,https://auth.globus.org/scopes/facd7ccc-c5f4-42aa-916b-a0e270e2c2a9/all

# Connector settings
CONNECTOR_STATE_SECRET=replace_with_long_random_secret
CONNECTOR_FERNET_KEY=replace_with_fernet_key
CONNECTOR_DB_PATH=server/globus_auth/tokens.db
CONNECTOR_BASE_URL=http://localhost:8000
CONNECTOR_SHARED_SECRET=replace_with_submit_api_key

# Optional ownership check against ClearML task owner
STRICT_CLEARML_OWNER_CHECK=false
CLEARML_API_HOST=
CLEARML_WEB_HOST=
CLEARML_FILES_HOST=
CLEARML_ACCESS_KEY=
CLEARML_SECRET_KEY=
